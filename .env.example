# Application
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-long-random-secret
API_PREFIX=/api/v1

# Database
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragsecret
POSTGRES_DB=enterprise_rag
DATABASE_URL=postgresql+asyncpg://rag:ragsecret@postgres:5432/enterprise_rag

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_CONCURRENCY=8

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
CHAT_MODEL=qwen2.5:7b-instruct
VISION_MODEL=qwen2.5-vl
EMBEDDING_MODEL=bge-m3
RERANKER_MODEL=bge-reranker-large

# Ingestion
KNOWLEDGE_ROOT=/data/knowledge
UPLOAD_ROOT=/data/uploads
MAX_UPLOAD_MB=500
INGESTION_WORKERS=40
CHUNK_SIZE=512
CHUNK_OVERLAP=64
ENABLE_OCR=true

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_K=8
HYBRID_VECTOR_WEIGHT=0.7

# Auth (JWT)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Ports (host)
NGINX_HTTP_PORT=80
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ClamAV (amd64 production only; use `docker compose --profile clamav up -d`)
ENABLE_VIRUS_SCAN=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
